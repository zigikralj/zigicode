---
import '../styles/components/CanvasDots.css';
---
<div class="canvas-container">
  <canvas id="dots-canvas"></canvas>
</div>



<script>
  // Particle class representing each dot
  class Particle {
    x: number = 0;
    y: number = 0;
    vx: number = 0;
    vy: number = 0;
    radius: number = 0;
    baseRadius: number = 0;
    color: string = '';

    constructor(canvasWidth: number, canvasHeight: number) {
      this.reset(canvasWidth, canvasHeight, true);
    }

    reset(canvasWidth: number, canvasHeight: number, fullRandom = false) {
      this.x = Math.random() * canvasWidth;
      this.y = fullRandom ? Math.random() * canvasHeight : canvasHeight + 10;
      this.vx = (Math.random() - 0.5) * 0.4;
      this.vy = (Math.random() - 0.5) * 0.4 - 0.1; // slow drift upwards
      this.baseRadius = Math.random() * 1.5 + 1;
      this.radius = this.baseRadius;
      
      // Green matrix/cyberpunk palette
      const colors = [
        'rgba(0, 255, 102, 0.45)', // Neon green
        'rgba(0, 242, 137, 0.4)',  // Cyber mint green
        'rgba(0, 170, 68, 0.3)',   // Medium green
      ];
      this.color = colors[Math.floor(Math.random() * colors.length)];
    }

    update(canvasWidth: number, canvasHeight: number, mouse: { x: number; y: number; active: boolean }) {
      this.x += this.vx;
      this.y += this.vy;

      // Mouse interactivity - push particles away slightly
      if (mouse.active) {
        const dx = this.x - mouse.x;
        const dy = this.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const maxDist = 120; // Interaction radius

        if (dist < maxDist) {
          const force = (maxDist - dist) / maxDist;
          const angle = Math.atan2(dy, dx);
          // Apply gentle repelling force
          this.x += Math.cos(angle) * force * 1.2;
          this.y += Math.sin(angle) * force * 1.2;
          
          // Slightly grow hovered particles
          this.radius = this.baseRadius + force * 1.5;
        } else {
          // Shrink back to normal
          if (this.radius > this.baseRadius) {
            this.radius -= 0.1;
          }
        }
      } else {
        if (this.radius > this.baseRadius) {
          this.radius -= 0.1;
        }
      }

      // Re-spawn if they drift out of boundary
      if (this.x < -20 || this.x > canvasWidth + 20 || this.y < -20 || this.y > canvasHeight + 20) {
        this.reset(canvasWidth, canvasHeight, false);
      }
    }

    draw(ctx: CanvasRenderingContext2D) {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fillStyle = this.color;
      ctx.shadowColor = this.color;
      ctx.shadowBlur = 4;
      ctx.fill();
    }
  }

  // Animation controller
  function initDots() {
    const canvas = document.getElementById('dots-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = (canvas.width = canvas.parentElement?.clientWidth || window.innerWidth);
    let height = (canvas.height = canvas.parentElement?.clientHeight || window.innerHeight);

    // Scaling particles based on viewport width
    const density = Math.min(width * height / 10000, 80);
    const particles: Particle[] = [];
    
    for (let i = 0; i < density; i++) {
      particles.push(new Particle(width, height));
    }

    const mouse = {
      x: 0,
      y: 0,
      active: false
    };

    // Listen to mouse events on the parent wrapper (which will be the Hero section)
    const parent = canvas.closest('section') || window;
    
    parent.addEventListener('mousemove', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      const rect = canvas.getBoundingClientRect();
      mouse.x = mouseEvent.clientX - rect.left;
      mouse.y = mouseEvent.clientY - rect.top;
      mouse.active = true;
    });

    parent.addEventListener('mouseleave', () => {
      mouse.active = false;
    });

    // Resize handling
    window.addEventListener('resize', () => {
      if (!canvas) return;
      const newWidth = canvas.parentElement?.clientWidth || window.innerWidth;
      const newHeight = canvas.parentElement?.clientHeight || window.innerHeight;
      
      if (Math.abs(newWidth - width) > 10 || Math.abs(newHeight - height) > 10) {
        width = canvas.width = newWidth;
        height = canvas.height = newHeight;
        
        // Readjust particle count
        const newDensity = Math.min(width * height / 10000, 80);
        particles.length = 0;
        for (let i = 0; i < newDensity; i++) {
          particles.push(new Particle(width, height));
        }
      }
    });

    // Drawing connections between particles
    function drawConnections() {
      if (!ctx) return;
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const p1 = particles[i];
          const p2 = particles[j];
          const dx = p1.x - p2.x;
          const dy = p1.y - p2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const maxDist = 95;

          if (dist < maxDist) {
            const alpha = (maxDist - dist) / maxDist * 0.15;
            ctx.beginPath();
            ctx.moveTo(p1.x, p1.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(0, 255, 102, ${alpha * 0.7})`;
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }
        }

        // Draw connections to mouse
        if (mouse.active) {
          const p = particles[i];
          const dx = p.x - mouse.x;
          const dy = p.y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const maxDist = 120;

          if (dist < maxDist) {
            const alpha = (maxDist - dist) / maxDist * 0.25;
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(mouse.x, mouse.y);
            
            // Neon cyan line to mouse
            ctx.strokeStyle = `rgba(0, 242, 137, ${alpha})`;
            ctx.lineWidth = 0.8;
            ctx.stroke();
          }
        }
      }
    }

    // Animation Loop
    function animate() {
      if (!ctx || !canvas) return;
      
      // Clear canvas with trace effect (slight transparent matrix black layer)
      ctx.fillStyle = 'rgba(5, 8, 6, 0.2)';
      ctx.shadowBlur = 0; // reset shadow
      ctx.fillRect(0, 0, width, height);
      
      // Update & Draw particles
      particles.forEach((p) => {
        p.update(width, height, mouse);
        p.draw(ctx);
      });

      // Connect particles
      drawConnections();

      requestAnimationFrame(animate);
    }

    // Start
    animate();
  }

  // Hook into Astro page lifecycle
  document.addEventListener('DOMContentLoaded', initDots);
  // Support Astro View Transitions if any
  document.addEventListener('astro:page-load', initDots);
</script>
