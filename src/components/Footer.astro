---
import '../styles/components/Footer.css';
---
<footer class="footer">
  <div class="footer-container container">
    <div class="footer-brand">
        <a href="#" class="logo">
          <img src={`${import.meta.env.BASE_URL}logo.png`} alt="Zigi Code Logo" class="logo-img" />
        </a>
      <p class="footer-tagline">Crafting elite, high-performance software solutions.</p>
    </div>

    <div class="footer-links">
      <div class="link-group">
        <h4>Navigation</h4>
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="#portfolio">Work</a>
      </div>
      
      <div class="link-group">
        <h4>Socials</h4>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="#contact">Contact</a>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom container">
    <p class="copyright">&copy; {new Date().getFullYear()} <span>Zigi Code</span>. All rights reserved. Designed with precision.</p>
  </div>
</footer>
