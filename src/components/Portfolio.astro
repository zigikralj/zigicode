---
import '../styles/components/Portfolio.css';
---
<section id="portfolio" class="portfolio-section">
  <div class="container">
    <div class="section-title">
      <h2>Selected Projects</h2>
    </div>

    <div class="projects-grid">
      <!-- Project 1 -->
      <div class="project-card glass-panel">
        <div class="project-image-fallback img-nebula">
          <div class="project-tags-overlay">
            <span>Next.js</span>
            <span>GraphQL</span>
            <span>AWS</span>
          </div>
        </div>
        <div class="project-content">
          <h3>Nebula Dashboard</h3>
          <p>
            An enterprise cloud analytics platform that handles millions of monthly events, providing low-latency queries and real-time visualization dashboards.
          </p>
          <a href="#contact" class="project-link">View Case Study &rarr;</a>
        </div>
      </div>

      <!-- Project 2 -->
      <div class="project-card glass-panel">
        <div class="project-image-fallback img-scribe">
          <div class="project-tags-overlay">
            <span>Astro</span>
            <span>TypeScript</span>
            <span>CSS Grid</span>
          </div>
        </div>
        <div class="project-content">
          <h3>Scribe CMS</h3>
          <p>
            A minimal, markdown-driven publishing system built for developers. Highly optimized structure yielding 100/100 performance scores across Google Lighthouse audits.
          </p>
          <a href="#contact" class="project-link">View Case Study &rarr;</a>
        </div>
      </div>

      <!-- Project 3 -->
      <div class="project-card glass-panel">
        <div class="project-image-fallback img-apex">
          <div class="project-tags-overlay">
            <span>SwiftUI</span>
            <span>Combine</span>
            <span>CoreData</span>
          </div>
        </div>
        <div class="project-content">
          <h3>Apex Trading Companion</h3>
          <p>
            A high-speed, native iOS cryptocurrency tracking app. Real-time WebSockets integration, secure local storage, and responsive charts.
          </p>
          <a href="#contact" class="project-link">View Case Study &rarr;</a>
        </div>
      </div>
    </div>

    <!-- Partners Sub-section -->
    <div class="partners-block">
      <h3>Trusted Collaborators & Partners</h3>
      <div class="partners-grid">
        <div class="partner-logo">ACME CORP</div>
        <div class="partner-logo">SYNAPSE LABS</div>
        <div class="partner-logo">VERTEX TECH</div>
        <div class="partner-logo">HELIX AI</div>
      </div>
    </div>
  </div>
</section>
